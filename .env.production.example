# Django Settings for Production
# Use this as a template when deploying to production
# Make sure to use strong, unique values

SECRET_KEY=your-strong-production-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# Neon PostgreSQL Database
# On Netlify, this is set automatically as NETLIFY_DATABASE_URL
# For other environments, set DATABASE_URL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
